<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView android:id="@+id/itemDate" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:textSize="12sp" android:textColor="#444444" />
    <TextView android:id="@+id/itemLat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="12sp" />
    <TextView android:id="@+id/itemLon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="12sp" />
    <TextView android:id="@+id/itemAlt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="12sp" />

</LinearLayout>